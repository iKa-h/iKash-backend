DIDIT_API_KEY=your_api_key_here
DIDIT_WEBHOOK_SECRET=your_webhook_secret_here
DIDIT_API_URL=https://verification.didit.me/v3
DIDIT_WORKFLOW_ID=your_workflow_id_here
KYC_CALLBACK_URL=http://localhost:3001/dashboard

STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=testnet
STELLAR_SIGNER_SECRET=your_stellar_secret_key_here

# Database (Supabase)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Trustless Work Escrow
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=your_trustless_work_api_key_here
TRUSTLESS_WORK_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# iKash Escrow Roles (Stellar public keys — generate on Testnet via Friendbot)
IKASH_TREASURY_ADDRESS=your_treasury_public_key_here
IKASH_SUPPORT_ADDRESS=your_support_public_key_here
# Optional comma-separated support identities allowed to join any order chat.
CHAT_SUPPORT_USER_IDS=
CHAT_SUPPORT_PUBLIC_KEYS=
# Secret of the treasury account — the backend signs the escrow deploy with this key
IKASH_DEPLOYER_SECRET=your_treasury_secret_key_here
IKASH_PLATFORM_FEE=1

# File Storage
# Set to "gcs" to use Google Cloud Storage (real or fake-gcs-server), or "mock" for a fake in-memory backend
STORAGE_PROVIDER=mock
# Bucket name used by the GCS storage provider
GCS_BUCKET_NAME=ikash-profile-images
# Set to http://localhost:4443 to connect to the local fake-gcs-server (requires docker-compose up)
# Leave empty to connect to real Google Cloud Storage (requires ADC or service account key)
STORAGE_ENDPOINT=
# GCP project ID (only used in production with real GCS)
# GCS_PROJECT_ID=your-gcp-project-id

# Local dev-only: allows temporary no-DB profile upload testing
MOCK_PROFILE_UPLOAD=false

# Send Crypto (wallet-to-wallet)
# Percentage of commission on the sent amount (optional; default 0.3).
# The fee is charged in USDC to IKASH_TREASURY_ADDRESS.
SEND_CRYPTO_FEE_PERCENT=0.3
